{
    "name": "flowrise-hms/patient",
    "type": "laravel-module",
    "description": "Patient management module for FlowRise HMS providing comprehensive patient registration, identification, demographics management, and emergency contact handling. Implements MRN auto-generation, UUID-based identifiers for interoperability, and PII encryption for data protection.",
    "authors": [
        {
            "name": "Flowrise Digital",
            "homepage": "https://github.com/Flowrise-HMS",
            "email": "flowrisedigitals@gmail.com"
        },
        {
            "name": "Mushe Abdul-Hakim",
            "email": "musheabdulhakim99@gmail.com",
            "homepage": "https://github.com/musheabdulhakim",
            "role": "Lead Developer"
        }
    ],
    "license": "MIT",
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {}
        }
    },
    "require": {
        "php": "^8.4",
        "flowrise-hms/core": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Modules\\Patient\\": "app/",
            "Modules\\Patient\\Database\\Factories\\": "database/factories/",
            "Modules\\Patient\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Patient\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
